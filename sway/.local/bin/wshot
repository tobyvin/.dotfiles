#!/bin/sh

# shellcheck disable=2046
outputs=$(swaymsg -t get_outputs | jq -r '.[].name')
image=$(mktemp --suffix=.png)

cleanup() {
	rm -f "$image"
	for out in $outputs; do
		swaymsg --quiet [app_id="swayimg_$out"] kill
	done
}

trap "trap - SIGTERM && cleanup" INT TERM EXIT

for out in $outputs; do
	swaymsg assign [app_id="swayimg_$out"] output "$out"
	swaymsg exec -- "grim -o'$out' - | swayimg --class='swayimg_$out' --scale=real --fullscreen -"
done

if ! slurp | grim -g - "$image" 2>/dev/null; then
	exit 1
fi

wl-copy --type image/png <"$image"

for out in $outputs; do
	swaymsg --quiet [app_id="swayimg_$out"] kill
done

notify-send 'Screenshot captured' \
	"Screenshot copied to clipboard" \
	--app-name=wshot \
	--hint=string:image-path:"file://$image" \
	--wait
