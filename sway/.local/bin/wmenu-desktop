#!/bin/sh

cache="${XDG_CACHE_HOME:-"$HOME/.cache"}/wmenu-desktop"
term="$TERMINAL -T '%c' -e"

if [ $# -eq 0 ]; then
	printf '%s\n' "$XDG_DATA_HOME" "$XDG_DATA_DIRS" |
		tr ':' '\n' |
		sed 's|/\?$|/applications|' |
		xargs fd . --extension=.desktop \
			-X desktop-entry.awk -v term="$term" \; 2>/dev/null |
		sort -t'	' -ubk2,2 |
		tee "$cache" | cut -f2
	exit 0
fi

if [ "$1" = '-' ]; then
	args="$(cat -)"
	if [ -z "$args" ]; then
		exit 0
	fi
	set -- "$args"
fi

while IFS='	' read -r entry name exec; do
	if [ "$name" = "$1" ]; then
		break
	fi
	unset exec
done <"$cache"

if [ -z "$exec" ]; then
	printf 'Failed to find "%s" in cache.\n' "$1" >&2
	exit 1
fi

printf '%s\n' "$exec"
# swaymsg exec --
