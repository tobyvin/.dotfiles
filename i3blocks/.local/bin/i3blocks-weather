#!/usr/bin/env python3

from enum import Enum
import json
import os
import re
import subprocess
import sys
import time
from typing import Any, Self

import requests


class NFWeather(Enum):
    def __init__(self, day, night):
        self.is_day: bool = True
        self.day = day
        self.night = night

    Clear = "", ""
    Cloudy = "", ""
    PartlyCloudy = "", ""
    Fog = "", ""
    Hail = "", ""
    Haze = "", ""
    Lightning = "", ""
    Rain = "", ""
    Showers = "", ""
    Sleet = "", ""
    Snow = "", ""
    Sprinkle = "", ""
    Thunderstorm = "", ""
    Windy = "", ""
    CloudyGusts = "", ""
    CloudyHigh = "", ""
    CloudyWindy = "", ""
    LightWind = "", ""
    RainMix = "", ""
    RainWind = "", ""
    SleetStorm = "", ""
    SnowThunderstorm = "", ""
    SnowWind = "", ""
    StormShowers = "", ""

    @property
    def icon(self) -> str:
        if self.is_day:
            return self.day
        else:
            return self.night

    @property
    def desc(self) -> str:
        return re.sub("([A-Z][a-z]+)(?=[A-Z])", r"\1 ", self.name)

    def version(self, is_day: bool) -> Self:
        self.is_day = is_day
        return self


WMO_CODES = {
    0: NFWeather.Clear,  # Sunny
    1: NFWeather.PartlyCloudy,  # MainlySunny
    2: NFWeather.CloudyHigh,  # PartlyCloudy
    3: NFWeather.Cloudy,  # Cloudy
    45: NFWeather.Fog,  # Foggy
    48: NFWeather.Fog,  # Foggy
    51: NFWeather.Sprinkle,  # LightDrizzle
    53: NFWeather.Rain,  # Drizzle
    55: NFWeather.RainWind,  # HeavyDrizzle
    56: NFWeather.Sleet,  # LightFreezingDrizzle
    57: NFWeather.Sleet,  # FreezingDrizzle
    61: NFWeather.Sprinkle,  # LightRain
    63: NFWeather.Rain,  # Rain
    65: NFWeather.RainWind,  # HeavyRain
    66: NFWeather.Sleet,  # LightFreezingRain
    67: NFWeather.Sleet,  # FreezingRain
    71: NFWeather.Snow,  # LightSnow
    73: NFWeather.Snow,  # Snow
    75: NFWeather.SnowWind,  # HeavySnow
    77: NFWeather.Hail,  # SnowGrains
    80: NFWeather.Sprinkle,  # LightShowers
    81: NFWeather.Showers,  # Showers
    82: NFWeather.StormShowers,  # HeavyShowers
    85: NFWeather.Snow,  # LightSnowShowers
    86: NFWeather.SnowWind,  # SnowShowers
    95: NFWeather.Thunderstorm,  # Thunderstorm
    96: NFWeather.SnowThunderstorm,  # LightThunderstormsWithHail
    99: NFWeather.SleetStorm,  # ThunderstormWithHail
}


class Weather:
    data: dict[str, Any] | None = None
    exception: Exception | None = None
    code: NFWeather = NFWeather.Clear
    temp: float | None = None
    unit: str | None = None

    def __init__(self, data: dict[str, Any], exception: Exception | None = None):
        self.data = data
        self.exception = exception

        match self.data:
            case {
                "current": {
                    "temperature_2m": float(temp),
                    "weather_code": int(code),
                    "is_day": int(is_day),
                },
                "current_units": {"temperature_2m": str(unit)},
            }:
                self.code = WMO_CODES[code].version(bool(is_day))
                self.temp = temp
                self.unit = unit

    def print(self):
        if self.data:
            output = {
                "full_text": " {} {}{} ".format(self.code.icon, self.temp, self.unit),
                "data": self.data,
            }
        else:
            output = {"full_text": " {} x ".format(self.code.icon)}
        if self.exception:
            output["color"] = f"#{os.environ.get('BASE16_COLOR_00_HEX')}"
            output["background"] = f"#{os.environ.get('BASE16_COLOR_08_HEX')}"

        print(json.dumps(output, ensure_ascii=False), flush=True)

    def notify(self):
        body = []
        if self.data:
            body.extend(
                [
                    "Weather: {} {}".format(self.code.icon, self.code.desc),
                    "Temperature: {}{}".format(self.temp, self.unit),
                ]
            )
        if self.exception:
            body.append("Error: {}".format(self.exception))
        subprocess.run(["notify-send", "Current Weather", "\n".join(body)])


BASE_URL = "https://api.open-meteo.com/v1/forecast?current=temperature_2m,weather_code,is_day&timezone=auto&forecast_days=1&latitude={latitude}&longitude={longitude}"


def get_weather():
    timeout = 1
    while True:
        resp = requests.get("https://ipinfo.io")
        if resp.text:
            break
        time.sleep(timeout)
        if timeout < 32:
            timeout *= 2
    (lat, long) = resp.json().get("loc", ",").split(",", 1)
    return requests.get(BASE_URL.format(latitude=lat, longitude=long)).json()


def main():
    try:
        weather = Weather(get_weather())
    except Exception as e:
        e.add_note("Failed to get weather API")
        print(e, file=sys.stderr)
        weather = Weather(json.loads(os.environ.get("data", "{}")), e)
        raise e

    weather.print()

    match int(os.environ.get("BLOCK_BUTTON", "0")):
        case 1:
            weather.notify()


if __name__ == "__main__":
    main()
