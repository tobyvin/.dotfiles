#!/usr/bin/env python3

import os
import sys

ICON = "\U000f02ca"  # 󰋊
UNITS = iter(["Ki", "Mi", "Gi", "Ti", "Pi"])
GiB = 2**30


def fmt_bytes(bytes: float) -> str:
    unit = ""
    while (bytes > 1024.0) and (u := next(UNITS)):
        unit = u
        bytes /= 1024.0
    return f"{round(bytes)}{unit}B"


def main():
    if len(sys.argv) > 1:
        path = sys.argv[1]
    else:
        path = "/"

    statvfs = os.statvfs(path)
    avail = statvfs.f_bavail * statvfs.f_frsize

    print(f" {ICON} {fmt_bytes(avail)} \n")
    if avail < (20 * GiB):
        print(f"#{os.environ.get('BASE16_COLOR_00_HEX')}")
        print(f"#{os.environ.get('BASE16_COLOR_0A_HEX')}")
    elif avail < (10 * GiB):
        print(f"#{os.environ.get('BASE16_COLOR_00_HEX')}")
        print(f"#{os.environ.get('BASE16_COLOR_08_HEX')}")


if __name__ == "__main__":
    main()
