#!/bin/sh
# shellcheck disable=SC2016

CALENDARS=$XDG_DATA_HOME/calendars

render() {
	khal list -a personal now eod --json all | jq -c \
		--arg black "#$BASE16_COLOR_00_HEX" \
		--arg white "#$BASE16_COLOR_05_HEX" \
		--arg yellow "#$BASE16_COLOR_0A_HEX" \
		--arg aqua "#$BASE16_COLOR_0C_HEX" \
		'(map(select(."all-day" != "True")) | first) // .[0] | if . then
				try ((.start | strptime("%y/%m/%d %H:%M") | mktime) - (now | localtime | mktime)) catch 3601 as $until |
				{
					"full_text": " 󰃭 " + ."start-end-time-style" + " " + .title[0:31] + " ",
					"short_text": " 󰃭 " + ."start-end-time-style" + " ",
					"color": if $until <= 3600 then $black else $white end,
					"background": if $until <= 0 then $aqua elif $until <= 3600 then $yellow else $black end,
				}
			else {} end'
}

timeout=$((60 - $(date +%S | sed 's/^0//')))
while true; do
	render

	inotifywait \
		--event modify \
		--event create \
		--event delete \
		--event close_write \
		--event moved_to \
		--event move \
		--monitor \
		--timeout ${timeout:-120} \
		--recursive \
		"$CALENDARS" 2>/dev/null |
		while read -r _; do
			sleep 1
			render
		done
	unset timeout
done
